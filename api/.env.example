API_PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USER=rag
DB_PASSWORD=ragpassword
DB_NAME=rag

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m

ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin1234

# Ollama — ชี้ไป local (docker) หรือ Ollama Cloud ก็ได้
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=            # ใส่เมื่อใช้ Ollama Cloud
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=bge-m3

# จัดอันดับผล retrieval ใหม่ด้วย chat model (แม่นขึ้น แลกกับ latency เพิ่ม ~1 LLM call)
RERANK_ENABLED=true

UPLOAD_DIR=./uploads
